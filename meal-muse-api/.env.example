# MealMuse API 环境配置
# 复制此文件为 .env 并修改对应值

# 环境（dev / staging / prod）
ENV=dev

# 数据库
DATABASE_URL=postgresql+asyncpg://xiaoyuer@localhost:5432/mealmuse

# Redis
REDIS_URL=redis://localhost:6379/0

# 安全（生产环境必须修改！）
SECRET_KEY=CHANGE-ME-IN-PRODUCTION

# ========== AI 多模型配置 ==========

# 当前使用的 AI 提供商（dashscope / xiaomi / openai / custom）
# 更换提供商后只需改这个值即可
AI_PROVIDER=xiaomi

# --- 通义千问 (DashScope) ---
DASHSCOPE_API_KEY=sk-你的通义千问API密钥
DASHSCOPE_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
DASHSCOPE_DEFAULT_MODEL=qwen-plus

# --- 小米 AI (Xiaomi) ---
# 小米 AI 提供 OpenAI 兼容接口，填写你的 API 密钥和地址
XIAOMI_API_KEY=你的小米AI密钥
XIAOMI_API_URL=https://token-plan-cn.xiaomimimo.com/v1
XIAOMI_DEFAULT_MODEL=mimo-v2.5-pro

# --- OpenAI ---
# OPENAI_API_KEY=sk-你的OpenAI密钥
# OPENAI_API_URL=https://api.openai.com/v1/chat/completions
# OPENAI_DEFAULT_MODEL=gpt-4o-mini

# --- 自定义 OpenAI 兼容 ---
# CUSTOM_API_KEY=
# CUSTOM_API_URL=
# CUSTOM_DEFAULT_MODEL=

# 场景模型别名（可选，不填则用各提供商的 default_model）
AI_FOOD_PARSE_MODEL=
AI_MEAL_PLAN_MODEL=

# ========== 其他 ==========

# MCP 外部服务
SPOONACULAR_API_KEY=
# 和风天气 (可选，不填则用 wttr.in 免费服务)
WEATHER_API_KEY=
# 高德地图 Web API Key (附近餐厅搜索)
AMAP_API_KEY=

# CORS（逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 短信服务
SMS_PROVIDER=dev
SMS_ACCESS_KEY=
SMS_ACCESS_SECRET=
SMS_SIGN_NAME=MealMuse
SMS_TEMPLATE_CODE=
