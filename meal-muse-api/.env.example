# MealMuse API 配置

# 环境：dev（开发）或 prod（生产）
ENV=dev

# 数据库连接（PostgreSQL）
DATABASE_URL=postgresql+asyncpg://xiaoyuer@localhost:5432/mealmuse

# Redis 连接
REDIS_URL=redis://localhost:6379/0

# JWT 密钥（生产环境必须设置固定值，否则每次重启 token 失效）
SECRET_KEY=your-secret-key-here

# Token 过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 通义千问 API Key（不设置则使用内置回复）
DASHSCOPE_API_KEY=

# CORS 允许的域名（逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 调试模式
DEBUG=True